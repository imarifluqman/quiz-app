# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?appName=AppName

# JWT Secret - Generate a strong random string (min 32 characters)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Email Configuration (Gmail App Password or SMTP provider)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Application URL (change in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: For production deployment
# NEXT_PUBLIC_APP_URL=https://your-domain.com
